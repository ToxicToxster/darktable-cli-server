# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# Limits
MAX_UPLOAD_BYTES=209715200
REQUEST_TIMEOUT=120
MAX_CONCURRENT_RENDERS=4
TEMP_DIR=/tmp/darktable-work

# Security level: 1=preview only, 2=restricted render (default), 3=full passthrough
SECURITY_LEVEL=2

# Auth secret (used when ACCESS_REQUIRE_API_KEY is enabled)
# API_KEY=your-secret-key

# Preview defaults
PREVIEW_FORMAT=jpg
PREVIEW_QUALITY=80
PREVIEW_WIDTH=2000
PREVIEW_HEIGHT=2000
PREVIEW_HQ=false
PREVIEW_UPSCALE=false
PREVIEW_APPLY_CUSTOM_PRESETS=false

# Allowed formats and extensions
ALLOWED_OUTPUT_FORMATS=jpg,jpeg,png,tif,tiff
ALLOWED_RAW_EXTENSIONS=.dng,.arw,.nef,.cr2,.cr3,.orf,.rw2,.raf,.pef,.srw

# --- Access security (all optional, disabled by default) ---
# Master switch (forced true at SECURITY_LEVEL=3)
ACCESS_SECURITY_ENABLED=false
# Require X-API-Key header (needs API_KEY to be set)
ACCESS_REQUIRE_API_KEY=false
# Restrict to loopback only (direct socket IP, no proxy trust)
ACCESS_LOCALHOST_ONLY=false
# IP/CIDR allowlist
ACCESS_ENABLE_IP_ALLOWLIST=false
ACCESS_IP_ALLOWLIST=
# CORS restriction (browser-only protection)
ACCESS_ENABLE_CORS_RESTRICTION=false
ACCESS_CORS_ALLOWED_ORIGINS=
# Rate limiting (in-memory, single-worker only)
ACCESS_ENABLE_RATE_LIMIT=false
ACCESS_RATE_LIMIT_RPM=60
