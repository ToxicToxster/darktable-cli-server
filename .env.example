# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# Limits
MAX_UPLOAD_BYTES=209715200
REQUEST_TIMEOUT=120
MAX_CONCURRENT_RENDERS=4
TEMP_DIR=/tmp/darktable-work

# Auth (uncomment to enable)
# API_KEY=your-secret-key

# Preview defaults
PREVIEW_FORMAT=jpg
PREVIEW_QUALITY=80
PREVIEW_WIDTH=2000
PREVIEW_HEIGHT=2000
PREVIEW_HQ=false
PREVIEW_UPSCALE=false
PREVIEW_APPLY_CUSTOM_PRESETS=false
PREVIEW_ALLOW_OVERRIDES=false

# Allowed formats and extensions
ALLOWED_OUTPUT_FORMATS=jpg,jpeg,png,tif,tiff
ALLOWED_RAW_EXTENSIONS=.dng,.arw,.nef,.cr2,.cr3,.orf,.rw2,.raf,.pef,.srw

# Advanced arg denylist (comma-separated, empty = no extra deny)
DT_ARG_DENYLIST=
